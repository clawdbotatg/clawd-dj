// deep acid (after Switch Angel) | genres: acid,techno | bpm: 140 | layers: kick acid stab
// lpenv slider ride from the video baked as a slow sine sweep (the lesson's known miss)
setcps(140/60/4)
$kick: s("sbd!4").duck("2:3:4").duckattack(.2).duckdepth(.8)
$acid: n(irand(10).sub(7).seg(16)).scale("c:minor").rib(46,1).distort("2.2:.3").s("sawtooth").lpf(200).lpenv(sine.range(.5,6).slow(8)).lpq(12).orbit(2)
$stab: s("supersaw").detune(1).rel(5).beat(2, 32).slow(2).orbit(3).fm("2").fmh(2.04).room(1).roomsize(6)
