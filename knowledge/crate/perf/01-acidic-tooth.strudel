// acidic tooth (eddyflux) | genres: acid,techno | bpm: 120 | layers: kick hats acid
// intro masks removed — arrangement is live mutes now
setcps(1)
$kick: s("bd*2").bank('RolandTR909')
$hats: s("hh*8").gain(saw.mul(saw.fast(2))).clip(sine).bank('RolandTR909')
$acid: note("[<g1 f1>/8](<3 5>,8)").clip(perlin.range(.15,1.5)).release(.1).s("sawtooth").lpf(sine.range(400,800).slow(16)).lpq(cosine.range(6,14).slow(3)).lpenv(sine.mul(4).slow(4)).lpd(.2).lpa(.02).ftype('24db').rarely(add(note(12))).room(.2).shape(.3).postgain(.5).superimpose(x=>x.add(note(12)).delay(.5).bpf(1000)).gain("[.2 1@3]*2")
