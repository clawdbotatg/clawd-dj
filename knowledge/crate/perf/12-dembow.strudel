// dembow groove (Strudel workshop) | genres: latin,dembow,pop | bpm: 100 | layers: drums bassline guitar accordion
$drums: sound("bd rim").bank("RolandTR707").delay(.5)
$bassline: n("[0 [~ 0] 4 [3 2] [0 ~] [0 ~] <0 2> ~]/2").scale("D2:minor").sound("sawtooth,triangle").lpf(sine.range(500,1100).slow(12))
$guitar: note("[~ [<[d3,a3,f4]!2 [d3,bb3,g4]!2> ~]]*2").sound("gm_electric_guitar_muted").delay(.5)
$accordion: n("<4 [3@3 4] [<2 0> ~@16] ~>").scale("D4:minor").sound("gm_accordion:2").room(2).gain(.4)
